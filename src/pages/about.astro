<style>
  /* Section spacing */
  h2 {
    margin-top: 2.5em;
    padding-top: 1em;
    border-top: 1px solid #e0e0e0;
  }

  h2:first-of-type {
    margin-top: 1.5em;
    border-top: none;
  }

  h3 {
    font-size: 16px;
    font-weight: bold;
    font-style: normal;
    margin-top: 1.2em;
    margin-bottom: 0.6em;
    color: #444;
  }

  .tech-line {
    margin: 0.25em 0;
    line-height: 1.5;
  }

  .tech-line em {
    font-style: italic;
    color: #666;
    min-width: 90px;
    display: inline-block;
  }

  /* Phase timeline */
  .phase-timeline {
    margin: 1.5em 0;
  }

  .experience-list {
    margin: 1.5em 0 2em 0;
  }

  .experience-item {
    margin-bottom: 1.4em;
    padding-left: 1em;
  }

  .experience-item:last-child {
    margin-bottom: 0;
  }

  .phase {
    margin-bottom: 2em;
  }

  .phase:last-child {
    margin-bottom: 0;
  }

  /* Phase divider — horizontal rule with label */
  .phase-divider {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 1.2em;
  }

  .phase-divider::before,
  .phase-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: #999;
  }

  .phase-divider span {
    font-size: 11px;
    font-weight: bold;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #666;
    white-space: nowrap;
  }

  /* Phase entries */
  .phase-entries {
    padding-left: 1em;
  }

  .phase-entry {
    margin-bottom: 1.2em;
  }

  .phase-entry:last-child {
    margin-bottom: 0;
  }

  /* Header row: location + date */
  .phase-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1em;
    margin-bottom: 0.15em;
  }

  .phase-locations {
    font-weight: bold;
    font-size: 15px;
  }

  .phase-date {
    font-size: 12px;
    color: #888;
    white-space: nowrap;
  }

  .phase-role {
    margin: 0 0 0.4em 0;
    font-size: 13px;
    color: #555;
  }

  /* Flag row — compact cluster above city names */
  .flag-row {
    display: flex;
    gap: 4px;
    margin-bottom: 2px;
  }

  .flag-row .flag,
  .sub-header .flag {
    width: 16px;
    height: 11px;
    image-rendering: pixelated;
  }

  /* Bullet lists */
  .bullets-circle {
    padding-left: 1.2em;
    margin: 0;
  }

  .bullets-circle li {
    list-style-type: circle;
    margin-bottom: 0.2em;
  }

  /* Summer deployments sub-section */
  .phase-sub {
    margin-top: 1em;
    padding-top: 0.8em;
    padding-left: 1em;
    border-left: 1px dashed #ccc;
  }

  .sub-header {
    font-size: 11px;
    font-weight: bold;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #888;
    margin: 0 0 0.8em 0;
  }

  .sub-entry {
    margin-bottom: 1em;
  }

  .sub-entry:last-child {
    margin-bottom: 0;
  }
</style>
